{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "prebuildCommand": "npx expo prebuild --platform android && python3 scripts/fix-gradle.py",
      "android": {
        "buildType": "apk"
      },
      "node": "20.19.4",
      "env": {
        "EAS_BUILD_WORKINGDIR": "mobile"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}